# Hermes 2.0 — template de ambiente da VPS Contabo.
# Na VPS: copiar p/ /opt/hermes/.env e preencher. NUNCA commitar o .env real (.gitignore cobre).
# Gerar tokens: python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# --- tokens fail-closed (boot falha se vazios) ---
HERMES_AUTH_TOKEN=
HERMES_INTERNAL_TOKEN=
HERMES_VM_AUTH_TOKEN=

# --- flags ---
FEATURE_LINKEDIN=off
HERMES_STRICT_MCP=0

# --- LLM (reusa Ollama do PC via Tailscale, mesmo IP que o Geronimo usa) ---
OLLAMA_URL=http://100.99.116.28:11434

# --- opcionais ---
TELEGRAM_BOT_TOKEN=
OPENROUTER_API_KEY=
