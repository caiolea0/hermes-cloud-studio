# =============================================================================
# Hermes Cloud Studio — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# --- VM Connection ---
VM_USER=hermes-gcp
VM_HOST=
PROXY_PORT=1081
PROXY_USER=hermes
PROXY_PASS=

# --- Dashboard Server ---
DASHBOARD_PORT=8500
HERMES_SYNC_INTERVAL=60

# --- VM API Bridge ---
HERMES_VM_API=http://YOUR_VM_IP:8420
AGENT_ZERO_URL=http://YOUR_VM_IP:50080
AGENT_ZERO_API_KEY=

# --- Google Places API ---
GOOGLE_PLACES_API_KEY=

# --- Authentication ---
HERMES_AUTH_TOKEN=
HERMES_VM_AUTH_TOKEN=

# --- LinkedIn ---
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_ACCOUNT_TYPE=free
LINKEDIN_PROXY=
LINKEDIN_PROXY_USER=
LINKEDIN_PROXY_PASS=

# --- OpenRouter (LLM) ---
OPENROUTER_API_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email Notifications ---
EMAIL_FROM=
EMAIL_TO=
EMAIL_APP_PASSWORD=
