# =============================================================================
# Hermes Cloud Studio — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# --- VM Connection ---
VM_USER=hermes-gcp
VM_HOST=
PROXY_PORT=55081
PROXY_USER=hermes
PROXY_PASS=

# --- Dashboard Server ---
DASHBOARD_PORT=55000
HERMES_SYNC_INTERVAL=60

# --- VM API Bridge ---
HERMES_VM_API=http://YOUR_VM_IP:8420
AGENT_ZERO_URL=http://YOUR_VM_IP:50080
AGENT_ZERO_API_KEY=

# --- Google Places API ---
GOOGLE_PLACES_API_KEY=

# --- Authentication ---
# Gerar: python -c "import secrets; print(secrets.token_urlsafe(32))"
HERMES_AUTH_TOKEN=
HERMES_VM_AUTH_TOKEN=
HERMES_INTERNAL_TOKEN=

# --- LinkedIn ---
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_ACCOUNT_TYPE=free
LINKEDIN_PROXY=
LINKEDIN_PROXY_USER=
LINKEDIN_PROXY_PASS=

# --- OpenRouter (LLM) ---
OPENROUTER_API_KEY=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email Notifications ---
EMAIL_FROM=
EMAIL_TO=
EMAIL_APP_PASSWORD=

# --- AgentMemory + VM bridge (override defaults se necessário) ---
AGENTMEMORY_URL=http://localhost:3111
HERMES_VM_RESTART_CMD=
HERMES_PC_EVENT_URL=http://127.0.0.1:55000/api/internal/linkedin/event
VM_API_PORT=8420
HERMES_HOME=
