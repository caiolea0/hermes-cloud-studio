# =============================================================================
# Hermes Cloud Studio — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# --- VM Connection ---
VM_USER=hermes-gcp
VM_HOST=
PROXY_PORT=55081
PROXY_USER=hermes
PROXY_PASS=

# --- Dashboard Server ---
DASHBOARD_PORT=55000
HERMES_SYNC_INTERVAL=60

# --- VM API Bridge ---
HERMES_VM_API=http://YOUR_VM_IP:8420
AGENT_ZERO_URL=http://YOUR_VM_IP:50080
AGENT_ZERO_API_KEY=

# --- Google Places API ---
GOOGLE_PLACES_API_KEY=

# --- Authentication ---
# Gerar: python -c "import secrets; print(secrets.token_urlsafe(32))"
HERMES_AUTH_TOKEN=
HERMES_VM_AUTH_TOKEN=
HERMES_INTERNAL_TOKEN=

# --- LinkedIn ---
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_ACCOUNT_TYPE=free
LINKEDIN_PROXY=
LINKEDIN_PROXY_USER=
LINKEDIN_PROXY_PASS=

# --- OpenRouter (LLM) ---
# P1 Hardening: rotacionar pos-audit via scripts/setup_openrouter_key.ps1
# Format: sk-or-v1-<40+ chars>. Dashboard: openrouter.ai → Settings → Keys.
OPENROUTER_API_KEY=

# --- Telegram (legacy — hermes_api_v2 + telegram_bridge.py) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- F.7 C4 Telegram bot Hermes dedicado (NAO Bolseye) ---
# P1 Hardening: SKIP rotacionar — bot novo criado 2026-06-16, owner decision formal.
# Format: <bot_id>:<secret>. Setup: scripts/setup_telegram_bot.ps1
HERMES_TELEGRAM_BOT_TOKEN=
HERMES_TELEGRAM_CHAT_ID=

# --- Email Notifications + Outreach Channel (MERGED-010 E.1) ---
# Gmail App Password: gerar em https://myaccount.google.com/apppasswords
EMAIL_FROM=
EMAIL_TO=
EMAIL_APP_PASSWORD=
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
# Caps Gmail free: 500/dia. Workspace pago: 2000/dia. Hourly = anti-burst.
EMAIL_DAILY_CAP=500
EMAIL_HOURLY_CAP=50
# Warmup ramp: dia 0 -> EMAIL_WARMUP_START_PCT * daily_cap. dia N -> EMAIL_WARMUP_END_PCT.
EMAIL_WARMUP_DAYS=14
EMAIL_WARMUP_START_PCT=0.10
EMAIL_WARMUP_END_PCT=0.80

# --- AgentMemory + VM bridge (override defaults se necessário) ---
AGENTMEMORY_URL=http://localhost:3111
HERMES_VM_RESTART_CMD=
HERMES_PC_EVENT_URL=http://127.0.0.1:55000/api/internal/linkedin/event
VM_API_PORT=8420
HERMES_HOME=

# --- Ollama Router (MERGED-014) ---
# PC tunnel reverso (RTX 2060 6GB) e' o primary. Migracao VM-GPU: trocar pra http://localhost:11434.
OLLAMA_URL=http://localhost:11434
# Fallback opcional (vazio = sem fallback; setar quando VM tiver Ollama proprio):
HERMES_OLLAMA_FALLBACK_URL=
# Models por task — qwen2.5:3b classificacao rapida, qwen2.5:7b-instruct PT-BR creative:
HERMES_OLLAMA_MODEL_CLASSIFY=qwen2.5:3b
HERMES_OLLAMA_MODEL_CREATIVE=qwen2.5:7b-instruct
HERMES_OLLAMA_CONNECT_TIMEOUT=3.0
HERMES_OLLAMA_REQUEST_TIMEOUT=45.0

# --- F.5.1 MCP Gateway (ContextForge/FastMCP 3.0) ---
# STRICT_MODE=0 (default, dev local): gateway down → warn-only, lifespan continua
# STRICT_MODE=1 (VM prod): gateway down → RuntimeError, lifespan abort (fail-closed audit)
HERMES_STRICT_MCP=0
HERMES_GATEWAY_URL=http://localhost:55401
# OAuth 2.1 bearer secret. Gerar: python -c "import secrets; print(secrets.token_urlsafe(32))"
# P1 Hardening: rotacionar pos-audit via scripts/setup_gateway_oauth_secret.ps1 (auto-gerado)
# Localhost loopback bypassa auth quando STRICT_MCP=0. Strict + non-loopback exige Bearer.
HERMES_GATEWAY_OAUTH_SECRET=

# R5 PHASE 1 --- Per-role bearers (server-trusted requester, defense-in-depth).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Auto-generate + deploy via: scripts/setup_gateway_role_bearers.ps1
# Each role has a unique bearer; gateway derives requester from bearer match.
# R5 PHASE 3 deprecate: remove HERMES_GATEWAY_OAUTH_SECRET when all callers migrated.
HERMES_GATEWAY_BEARER_BRAIN=
HERMES_GATEWAY_BEARER_BRAIN_CORE=
HERMES_GATEWAY_BEARER_BRAIN_F4=
HERMES_GATEWAY_BEARER_BRAIN_F5=
HERMES_GATEWAY_BEARER_BRAIN_F6=
HERMES_GATEWAY_BEARER_BRAIN_F7_COBAIA=
HERMES_GATEWAY_BEARER_BRAIN_F7_COBAIA_AUTOTUNE=
HERMES_GATEWAY_BEARER_BRAIN_F8=
HERMES_GATEWAY_BEARER_BRAIN_F9=
HERMES_GATEWAY_BEARER_BREADCRUMB=
HERMES_GATEWAY_BEARER_API=

# --- F.5.6 Public MCPs integration ---
# F.5.6a — GitHub MCP (F.4 PR-based skill deploy). Scope: repo + workflow.
# P1 Hardening: rotacionar pos-audit via scripts/setup_github_pat.ps1
# Format: ghp_<39 chars>. Dashboard: github.com/settings/tokens
GITHUB_PERSONAL_ACCESS_TOKEN=

# F.4 GitHub webhook HMAC SHA-256 — match GitHub repo webhook config.
# P1 Hardening: rotacionar pos-audit via scripts/setup_github_webhook_secret.ps1
# Format: <random 64 char hex>. Re-gerar: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=

# F.5.6b — Sentry MCP (@sentry/mcp-server). F.4 auto-disable + F.7 cobaia error tracking.
# https://sentry.io/settings/auth-tokens/ → scopes: project:read, issue:read, event:read.
# Required env name SENTRY_ACCESS_TOKEN (NOT _AUTH_TOKEN — package contract).
SENTRY_ACCESS_TOKEN=

# F.5.6c — Postgres MCP (D4 VALIDATION RESULT: FALLBACK self-host Docker crystaldba/postgres-mcp).
# Owner deploys Postgres instance VM-local (e.g. docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=... postgres:16)
# + sets DATABASE_URI abaixo. F.6 Brain.decide read-only intro (--access-mode=restricted).
DATABASE_URI=

# F.5.6e — Omnisearch MCP (mcp-omnisearch multi-engine). F.6 Brain web research + F.7 cobaia discovery.
# Provider keys: pelo menos 1 obrigatório. Tavily free tier 1000 req/mo recomendado.
# https://tavily.com/, https://brave.com/search/api/, https://kagi.com/settings?p=api
TAVILY_API_KEY=
BRAVE_API_KEY=
KAGI_API_KEY=
PERPLEXITY_API_KEY=
FIRECRAWL_API_KEY=
JINA_AI_API_KEY=

# --- F.5.7 + F.6.2 NVIDIA NIM Free Tier ---
# Cadastrar build.nvidia.com → Account → API Keys → Generate.
# Format: nvapi-<base64>. NUNCA commitar valor real. Hermes routing matrix consume T1+T2.
# P1 Hardening: SKIP rotacionar — owner decision formal (risco aceito, key ativa em uso).
HERMES_NIM_API_KEY=

# --- F.6.2 Brain smoke offline mode ---
# 1 (default) → MockDispatcher deterministic, no network. CI safe.
# 0           → real gateway dispatch (NIM + Ollama PC fallback).
HERMES_BRAIN_OFFLINE=1

# --- F.6.2 Ollama PC fallback (T3 routing matrix) ---
# Used by mcps/hermes-llm routing matrix as T3 fallback when NIM exhausted/down.
HERMES_OLLAMA_PC_URL=http://localhost:11434

# =============================================================================
# F.7 Cobaia Live Ops (set when warmup activation — see F7-OWNER-ACTIONS.md)
# =============================================================================
# COBAIA_LI_AT: extract via Chrome DevTools — Application > Cookies >
# linkedin.com > li_at > copy Value field. DEFERRED until owner finalize
# cobaia profile (All-Star + 50 conexoes seed + 2-4 posts organicos).
COBAIA_LI_AT=
COBAIA_ACCOUNT_EMAIL=
COBAIA_ACCOUNT_TYPE=free
COBAIA_SESSION_FILE=~/.hermes/sessions/cobaia.json

# F.3 Lab LinkedIn account (SEPARATE — NAO producao NAO cobaia)
LINKEDIN_LAB_EMAIL=
LINKEDIN_LAB_PASSWORD=
LINKEDIN_LAB_ACCOUNT_TYPE=free

# F.7 P5 Hunter.io email verifier (Task 6 + MCP HARD REQ)
# Free tier: 25 verifies/mo + 100 searches/mo + 15 req/min rate limit
# Setup: scripts/setup_hunter_key.ps1 (PC + VM bytes-level stdin pattern)
# Format: hex lowercase 30+ chars. Dashboard: hunter.io Settings > API
HUNTER_API_KEY=
