{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hermes",
  "version": "1.0.0",
  "identifier": "com.hermes.commandcenter",
  "build": {
    "devUrl": "http://localhost:55000",
    "frontendDist": "http://localhost:55000"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Hermes Command Center",
        "url": "http://localhost:55000",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
